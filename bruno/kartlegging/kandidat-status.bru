meta {
  name: kandidat-status
  type: http
  seq: 1
}

get {
  url: http://localhost:8080/api/v1/kartleggingssporsmal/kandidat-status
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:pre-request {
  await bru.runRequest("mock-auth/tokenx/create tokenx");
}

settings {
  encodeUrl: true
  timeout: 0
}
